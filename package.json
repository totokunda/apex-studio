{
  "name": "apex-studio",
  "description": "Apex Studio",
  "version": "0.1.0",
  "private": true,
  "type": "module",
  "author": {
    "email": "totokunda@gmail.com",
    "name": "Totokunda"
  },
  "main": "packages/entry-point.mjs",
  "workspaces": [
    "packages/*"
  ],
  "engines": {
    "node": ">=23.0.0"
  },
  "scripts": {
    "build": "npm run build -ws --if-present",
    "compile": "npm run build && electron-builder build --config electron-builder.mjs",
    "test": "npx playwright test ./tests/e2e.spec.ts",
    "start": "node packages/dev-mode.js",
    "typecheck": "npm run typecheck -ws --if-present"
  },
  "devDependencies": {
    "@npmcli/map-workspaces": "5.0.0",
    "@playwright/test": "1.55.0",
    "@types/node": "24.5.2",
    "create-vite": "7.1.2",
    "electron": "38.1.2",
    "electron-builder": "26.0.12",
    "glob": "11.0.3",
    "playwright": "^1.55.0",
    "prettier": "^3.7.1"
  },
  "dependencies": {
    "@app/main": "*",
    "@fontsource/lato": "^5.2.7",
    "@soundtouchjs/audio-worklet": "^0.2.1",
    "mime": "^4.1.0",
    "soundtouchjs": "^0.2.1",
    "ws": "^8.18.3"
  }
}
